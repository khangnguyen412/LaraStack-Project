    "components": {
        "schemas": {
            "Exception": {
                "required": [
                    "errorCode",
                    "errorMessage",
                    "data"
                ],
                "properties": {
                    "errorCode": {
                        "type": "string",
                        "example": "ERROR_CODE"
                    },
                    "errorMessage": {
                        "type": "string",
                        "example": "Error message."
                    },
                    "data": {
                        "type": "array",
                        "items": {
                            "type": "object"
                        },
                        "example": []
                    }
                },
                "type": "object"
            },
            "Permissions": {
                "required": [
                    "permission_name"
                ],
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": "1"
                    },
                    "name": {
                        "type": "string",
                        "uniqueItems": true,
                        "example": "admin"
                    },
                    "description": {
                        "type": "string",
                        "example": "web"
                    }
                },
                "type": "object"
            },
            "Roles": {
                "required": [
                    "role_name"
                ],
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": "1"
                    },
                    "name": {
                        "type": "string",
                        "uniqueItems": true,
                        "example": "admin"
                    },
                    "description": {
                        "type": "string",
                        "example": "web"
                    }
                },
                "type": "object"
            },
            "Users": {
                "properties": {
                    "id": {
                        "type": "string",
                        "format": "uuid",
                        "example": "5d1e8b2a-0a2b-4c0e-9a1b-f6b9a56a9a11"
                    },
                    "user_name": {
                        "type": "string",
                        "example": "jdoe"
                    },
                    "display_name": {
                        "type": "string",
                        "example": "John Doe"
                    },
                    "email": {
                        "type": "string",
                        "format": "email",
                        "example": "john@example.com"
                    },
                    "email_verified_at": {
                        "type": "string",
                        "format": "date-time",
                        "example": "2023-01-01T12:00:00Z",
                        "nullable": true
                    },
                    "password": {
                        "type": "string",
                        "writeOnly": true,
                        "example": "password123"
                    },
                    "address": {
                        "type": "string",
                        "example": "123 Main St"
                    },
                    "phone": {
                        "type": "string",
                        "example": "1234567890"
                    },
                    "bio": {
                        "type": "string",
                        "example": "A passionate developer",
                        "nullable": true
                    },
                    "avatar": {
                        "type": "string",
                        "example": "avatar.jpg",
                        "nullable": true
                    },
                    "deleted_at": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    },
                    "updated_at": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    },
                    "role_id": {
                        "type": "string",
                        "example": "1"
                    },
                    "role": {
                        "$ref": "#/components/schemas/Roles"
                    }
                },
                "type": "object"
            }
        },
